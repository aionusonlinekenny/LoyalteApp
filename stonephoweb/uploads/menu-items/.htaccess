# Allow access to uploaded images
<Files "*">
    Order allow,deny
    Allow from all
</Files>

# Only allow image files
<FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
    Order allow,deny
    Allow from all
</FilesMatch>

# Block PHP execution
<FilesMatch "\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>